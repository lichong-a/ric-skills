{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ric-skills.dev/schemas/dispatch.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["run_id", "actor_id", "role", "objective", "scope", "non_goals", "source_revision", "fresh_context", "read_only", "required_skills", "expected_output"],
  "properties": {
    "run_id": {"type": "string", "minLength": 1},
    "actor_id": {"type": "string", "minLength": 1},
    "role": {
      "enum": [
        "implementer",
        "fixer",
        "failure-triager",
        "requirements-reviewer",
        "requirements-security-reviewer",
        "design-reviewer",
        "design-security-reviewer",
        "code-reviewer",
        "security-reviewer",
        "test-executor",
        "visual-reviewer",
        "design-qa-reviewer",
        "acceptance-validator",
        "adjudicator"
      ]
    },
    "objective": {"type": "string", "minLength": 1},
    "scope": {"type": "array", "items": {"type": "string"}},
    "non_goals": {"type": "array", "items": {"type": "string"}},
    "source_revision": {"type": "string", "minLength": 1},
    "artifact_version": {"type": "string"},
    "constraints": {"type": "array", "items": {"type": "string"}},
    "fresh_context": {"type": "boolean"},
    "read_only": {"type": "boolean"},
    "required_skills": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
    "capabilities": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
    "expected_output": {"type": "string", "minLength": 1}
  }
}
