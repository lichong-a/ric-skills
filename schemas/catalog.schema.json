{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ric-skills.dev/schemas/catalog.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "roles", "capabilities", "skills"],
  "properties": {
    "version": {"type": "integer", "const": 1},
    "roles": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
    "capabilities": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
    "skills": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["description", "allowed_roles", "default_role", "domains", "required_companions", "optional_companions", "conflicts", "quality_gates", "capability_routes"],
        "properties": {
          "description": {"type": "string", "minLength": 1},
          "allowed_roles": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
          "default_role": {"type": "string"},
          "domains": {"type": "array", "items": {"type": "string"}},
          "required_companions": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
          "optional_companions": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
          "conflicts": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
          "quality_gates": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
          "conditional_quality_gates": {
            "type": "object",
            "additionalProperties": {"type": "array", "uniqueItems": true, "items": {"type": "string"}}
          },
          "gate_types": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
          "capability_routes": {"type": "array", "uniqueItems": true, "items": {"type": "string"}}
        }
      }
    }
  }
}
