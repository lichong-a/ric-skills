{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ric-skills.dev/schemas/live-eval-result.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["run_id", "source_revision", "status", "results"],
  "properties": {
    "run_id": {"type": "string", "minLength": 1},
    "source_revision": {"type": "string", "minLength": 1},
    "status": {"enum": ["PASS", "BLOCKED"]},
    "results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["scenario_id", "adapter", "fresh_context", "result", "transcript_sha256", "redacted_summary", "loaded_skills", "gate_evidence", "validation_errors", "invocation_id"],
        "properties": {
          "scenario_id": {"type": "string"},
          "adapter": {"enum": ["codex-subagent", "isolated-thread", "openai-agents-sdk", "external-command"]},
          "fresh_context": {"type": "boolean"},
          "result": {"enum": ["PASS", "FAIL", "BLOCKED"]},
          "transcript_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
          "redacted_summary": {"type": "string"},
          "gate_evidence": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["gate", "actor_id", "role", "loaded_skills", "fresh_context", "result", "evidence_path", "evidence_sha256"],
              "properties": {
                "gate": {"type": "string"},
                "actor_id": {"type": "string"},
                "role": {"type": "string", "minLength": 1},
                "loaded_skills": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
                "fresh_context": {"const": true},
                "result": {"enum": ["PASS", "PASS_WITH_ADVISORIES"]},
                "evidence_path": {"type": "string", "minLength": 1},
                "evidence_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
              }
            }
          },
          "loaded_skills": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
          "validation_errors": {"type": "array", "items": {"type": "string"}},
          "invocation_id": {"type": "string"},
          "adapter_claim": {"type": "object"},
          "dispatched_scenario": {"type": "object"}
        }
      }
    }
  }
}
