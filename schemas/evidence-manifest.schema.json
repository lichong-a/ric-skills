{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ric-skills.dev/schemas/evidence-manifest.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["run_id", "status", "source_revision", "acceptance_coverage", "evidence"],
  "properties": {
    "run_id": {"type": "string", "minLength": 1},
    "status": {"enum": ["PASS", "PASS_WITH_ADVISORIES", "FAIL_REWORK", "BLOCKED", "ESCALATE"]},
    "source_revision": {"type": "string"},
    "acceptance_coverage": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "status", "evidence_ids"],
        "properties": {
          "id": {"type": "string"},
          "status": {"enum": ["PASS", "FAIL", "BLOCKED", "NOT_RUN"]},
          "evidence_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string"}}
        }
      }
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "type", "path", "sha256", "result", "source_revision"],
        "properties": {
          "id": {"type": "string"},
          "type": {"enum": ["command", "test-report", "build", "contract", "diff", "log", "screenshot", "browser-trace", "review", "document", "video", "motion-trace", "performance-profile", "accessibility-report"]},
          "path": {"type": "string"},
          "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
          "result": {"enum": ["PASS", "FAIL", "BLOCKED", "NOT_RUN"]},
          "source_revision": {"type": "string"}
        }
      }
    }
  }
}
