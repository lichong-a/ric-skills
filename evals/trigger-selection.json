{
  "version": 1,
  "kind": "trigger-selection",
  "description": "Prompts that must select one primary executor plus required policies and gates.",
  "cases": [
    {
      "id": "react-admin-console",
      "prompt": "Create a React and shadcn tenant administration console with RBAC, audit logs, multilingual UI, and browser verification.",
      "expected": {
        "primary": "ric-admin-console",
        "required": [
          "ric-delivery-loop",
          "ric-agent-operating-rules",
          "ric-security-review",
          "ric-testing-quality",
          "ric-code-review",
          "ric-acceptance-validation",
          "ric-visual-design-review",
          "ric-design-qa"
        ],
        "excluded": [
          "ric-design-taste-frontend"
        ]
      }
    },
    {
      "id": "public-product-frontend",
      "prompt": "Build a high-impact public product landing page with generated brand assets and a distinctive responsive visual direction.",
      "expected": {
        "primary": "ric-design-taste-frontend",
        "required": [
          "ric-delivery-loop",
          "ric-imagegen-runtime",
          "ric-visual-design-review",
          "ric-design-qa",
          "ric-testing-quality",
          "ric-acceptance-validation"
        ],
        "excluded": [
          "ric-admin-console"
        ]
      }
    },
    {
